{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/eventdrivenarchitecture/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/eventdrivenarchitecture/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/eventdrivenarchitecture",
  "projects": {
    "eventdrivenarchitecture": {
      "type": "application",
      "root": "apps/eventdrivenarchitecture",
      "entryFile": "main",
      "sourceRoot": "apps/eventdrivenarchitecture/src",
      "compilerOptions": {
        "tsConfigPath": "apps/eventdrivenarchitecture/tsconfig.app.json"
      }
    },
    "restaurant": {
      "type": "application",
      "root": "apps/restaurant",
      "entryFile": "main",
      "sourceRoot": "apps/restaurant/src",
      "compilerOptions": {
        "tsConfigPath": "apps/restaurant/tsconfig.app.json"
      }
    },
    "restaurant-service": {
      "type": "application",
      "root": "apps/restaurant-service",
      "entryFile": "main",
      "sourceRoot": "apps/restaurant-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/restaurant-service/tsconfig.app.json"
      }
    }
  }
}